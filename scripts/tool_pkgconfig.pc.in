prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${exec_prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: libxstream
Description: Specialized tensor operations
URL: https://github.com/hfp/libxstream/
Version: @LIBXSTREAM_VERSION_STRING@

Cflags: -I${includedir}
Libs: -L${libdir} -lxstream
@LIBS_PRIVATE@
@REQUIRES_PRIVATE@
